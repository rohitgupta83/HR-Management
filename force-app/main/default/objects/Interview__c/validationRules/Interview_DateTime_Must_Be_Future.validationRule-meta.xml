<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Interview_DateTime_Must_Be_Future</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  OR(ISNEW(), ISCHANGED(Interview_DateTime__c)),
  Interview_DateTime__c &lt; NOW()
)</errorConditionFormula>
    <errorMessage>Interview Date &amp; Time must be set in the future.</errorMessage>
    <errorDisplayField>Interview_DateTime__c</errorDisplayField>
</ValidationRule>
