<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Rating_Required_When_Completed</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  ISPICKVAL(Status__c, "Completed"),
  ISBLANK(TEXT(Rating__c))
)</errorConditionFormula>
    <errorMessage>Rating is required when Interview Status is Completed.</errorMessage>
    <errorDisplayField>Rating__c</errorDisplayField>
</ValidationRule>
