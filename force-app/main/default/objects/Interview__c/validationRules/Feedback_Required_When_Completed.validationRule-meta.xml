<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Feedback_Required_When_Completed</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  ISPICKVAL(Status__c, "Completed"),
  ISBLANK(Feedback__c)
)</errorConditionFormula>
    <errorMessage>Feedback is required when Interview Status is Completed.</errorMessage>
    <errorDisplayField>Feedback__c</errorDisplayField>
</ValidationRule>
